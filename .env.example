# dev-diary-mcp .env template
# Copy to .env and fill in real values. Never commit .env.

# REST API auth — single shared bearer token
DIARY_TOKEN=replace-me-with-a-long-random-string

# Database
DIARY_DB_PATH=data/diary.db

# Embeddings provider: "watsonx" or "local"
EMBEDDINGS_PROVIDER=local

# watsonx.ai (only if EMBEDDINGS_PROVIDER=watsonx)
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_EMBED_MODEL=ibm/slate-30m-english-rtrvr

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWLIST_USER_IDS=  # comma-separated numeric IDs

# Voice transcription: "whisper-local" or "watsonx-stt"
TRANSCRIPTION_PROVIDER=whisper-local

# Web UI
VITE_API_BASE_URL=http://localhost:8000
