# Cortex .env template
# Copy to .env and fill in real values. Never commit .env.

# REST API auth — single shared bearer token
DIARY_TOKEN=replace-me-with-a-long-random-string

# Database
DIARY_DB_PATH=data/diary.db

# Embeddings provider: "watsonx" or "local"
EMBEDDINGS_PROVIDER=local

# LLM provider: "watsonx" (Granite 8B cloud) | "local" (Granite 2B GGUF) | "off"
# "off" disables /chat, /generate/summary, /generate/report (return 503).
LLM_PROVIDER=off

# watsonx.ai (used if EMBEDDINGS_PROVIDER=watsonx OR LLM_PROVIDER=watsonx)
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_EMBED_MODEL=ibm/slate-30m-english-rtrvr
WATSONX_LLM_MODEL=ibm/granite-3-8b-instruct

# Local Granite (used if LLM_PROVIDER=local).
# Download:  huggingface-cli download ibm-granite/granite-3.1-2b-instruct-GGUF \
#              granite-3.1-2b-instruct-Q4_K_M.gguf -d models/
LOCAL_LLM_GGUF_PATH=models/granite-3.1-2b-instruct-Q4_K_M.gguf
LOCAL_LLM_N_CTX=4096
LOCAL_LLM_N_THREADS=0

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWLIST_USER_IDS=  # comma-separated numeric IDs

# Voice transcription: "whisper-local" or "watsonx-stt"
TRANSCRIPTION_PROVIDER=whisper-local

# Web UI
# For local development: http://localhost:8080
# For mobile/network access: http://192.168.10.8:8080
VITE_API_BASE_URL=http://localhost:8080
