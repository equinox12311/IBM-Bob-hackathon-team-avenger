{
  "expo": {
    "name": "Cortex",
    "slug": "cortex-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "cortex",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f62fe"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cortex.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f62fe"
      },
      "package": "com.cortex.mobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Cortex uses the camera to scan the pairing QR printed by `make pair`."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
